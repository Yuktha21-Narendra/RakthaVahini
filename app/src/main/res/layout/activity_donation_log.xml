<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🩸 Donation Log"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#C0392B"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnPickDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pick Donation Date"
        android:backgroundTint="#F1948A"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvDonationDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No date selected"
        android:textColor="#888888"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnSaveDonation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Log Donation"
        android:backgroundTint="#C0392B"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Donation History"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#444444"
        android:layout_marginBottom="8dp"/>

    <ListView
        android:id="@+id/listDonations"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>