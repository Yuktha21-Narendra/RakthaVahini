<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🩸 RakthaVahini"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#C0392B"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Find a Blood Donor"
        android:textSize="13sp"
        android:textColor="#888888"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnEmergency"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="🚨 EMERGENCY - Find Any Donor NOW"
        android:textSize="14sp"
        android:textStyle="bold"
        android:backgroundTint="#8B0000"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="I am available to donate:"
            android:textSize="13sp"
            android:textColor="#444444"/>

        <Switch
            android:id="@+id/switchAvailable"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:thumbTint="#C0392B"
            android:trackTint="#F1948A"/>

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Search by Blood Group"
        android:textColor="#444444"
        android:layout_marginBottom="8dp"/>

    <Spinner
        android:id="@+id/spinnerBloodGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/rounded_edittext"/>

    <Button
        android:id="@+id/btnSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Search Donors"
        android:backgroundTint="#C0392B"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"/>

    <ListView
        android:id="@+id/listViewDonors"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:dividerHeight="8dp"/>

    <Button
        android:id="@+id/btnDonationLog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="My Donation Log"
        android:backgroundTint="#E74C3C"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Logout"
        android:backgroundTint="#888888"
        android:textColor="#FFFFFF"/>

</LinearLayout>